<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CodelingoApp.Views.HomePage"
             Title="Home">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="Home" FontSize="28" FontAttributes="Bold" />

            <Frame Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="PointsLabel"
                           Text="Current Points: 0"
                           FontAttributes="Bold" />
                    <Label x:Name="StreakLabel"
                           Text="Streak: 0 days" />
                    <Label x:Name="PlanLabel"
                           Text="Plan: Free" />
                    <Label x:Name="LevelLabel"
                           Text="Level: 1" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="Category" />
            <Picker x:Name="CategoryPicker" Title="Select category">
                <Picker.Items>
                    <x:String>All</x:String>
                    <x:String>Web</x:String>
                    <x:String>Programming</x:String>
                    <x:String>DSA</x:String>
                    <x:String>Database</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Difficulty" />
            <Picker x:Name="DifficultyPicker" Title="Select difficulty">
                <Picker.Items>
                    <x:String>All</x:String>
                    <x:String>Easy</x:String>
                    <x:String>Medium</x:String>
                </Picker.Items>
            </Picker>

            <Button Text="Start Sample Quiz" Clicked="OnStartQuizClicked" />
            <Button Text="Generate AI Quiz" Clicked="OnAiQuizClicked" />
            <Button Text="Leaderboard" Clicked="OnLeaderboardClicked" />
            <Button Text="Analytics" Clicked="OnAnalyticsClicked" />
            <Button Text="Profile" Clicked="OnProfileClicked" />
            <Button Text="Subscription" Clicked="OnSubscriptionClicked" />
            <Button Text="Logout" Clicked="OnLogoutClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>