<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CodelingoApp.Views.SubscriptionPage"
             Title="Subscription">
    <VerticalStackLayout Padding="20" Spacing="16">
        <Label Text="Subscription" FontSize="28" FontAttributes="Bold" />
        <Frame Padding="16">
            <VerticalStackLayout Spacing="8">
                <Label Text="Free Plan" FontAttributes="Bold" />
                <Label Text="Limited quizzes, no AI questions" />
            </VerticalStackLayout>
        </Frame>
        <Frame Padding="16">
            <VerticalStackLayout Spacing="8">
                <Label Text="Premium Plan" FontAttributes="Bold" />
                <Label Text="Unlimited quizzes, AI content, analytics" />
            </VerticalStackLayout>
        </Frame>
    </VerticalStackLayout>
</ContentPage>
