<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CodelingoApp.Views.AnalyticsPage"
             Title="Analytics">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="Premium Analytics"
                   FontSize="28"
                   FontAttributes="Bold" />

            <Label x:Name="StatusLabel"
                   Text="Loading..." />

            <Frame Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="TotalQuizzesLabel" Text="Total Quizzes: -" />
                    <Label x:Name="AverageAccuracyLabel" Text="Average Accuracy: -" />
                    <Label x:Name="BestScoreLabel" Text="Best Score: -" />
                    <Label x:Name="CurrentStreakLabel" Text="Current Streak: -" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>