<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CodelingoApp.Views.LeaderboardPage"
             Title="Leaderboard">

    <VerticalStackLayout Padding="20">
        <Label Text="Leaderboard"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <CollectionView x:Name="LeaderboardList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="4" Padding="10">
                        <HorizontalStackLayout>
                            <Label Text="{Binding Username}" FontAttributes="Bold" />
                            <Label Text="{Binding Points}" HorizontalOptions="EndAndExpand" />
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>