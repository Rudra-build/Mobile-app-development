<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CodelingoApp.Views.ResultsPage"
             Title="Results">

    <VerticalStackLayout Padding="24" Spacing="20" VerticalOptions="Center">

        <Label Text="Quiz Complete"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Label x:Name="ScoreLabel"
               Text="Score: 0/5"
               FontSize="22"
               HorizontalOptions="Center" />

        <Label x:Name="AccuracyLabel"
               Text="Accuracy: 0%"
               FontSize="18"
               HorizontalOptions="Center" />

        <Label x:Name="SummaryLabel"
               Text="Summary goes here"
               FontSize="18"
               HorizontalOptions="Center" />

        <Label x:Name="PointsLabel"
               Text="Points earned: 0"
               FontSize="18"
               HorizontalOptions="Center" />

        <Button Text="Back to Home"
                Clicked="OnBackHomeClicked" />

    </VerticalStackLayout>
</ContentPage>