<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CodelingoApp.Views.ResultsPage"
             Title="Results">
    <VerticalStackLayout Padding="20" Spacing="16" VerticalOptions="Center">
        <Label Text="Your Result" FontSize="30" FontAttributes="Bold" HorizontalOptions="Center" />
        <Label Text="Score: 4/5" HorizontalOptions="Center" />
        <Label Text="Great job!" HorizontalOptions="Center" />
        <Button Text="Back Home" Clicked="OnBackHomeClicked" />
    </VerticalStackLayout>
</ContentPage>
