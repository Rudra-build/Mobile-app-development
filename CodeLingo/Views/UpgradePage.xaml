<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CodeLingo.Views.UpgradePage"
             Title="Upgrade to Premium">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Header -->
            <Label Text="Choose Your Plan"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>
            <Label Text="Unlock the full CodeLingo experience"
                   FontSize="14"
                   TextColor="Gray"
                   HorizontalOptions="Center"/>

            <!-- FREE Card -->
            <Frame BackgroundColor="#F5F5F5"
                   CornerRadius="16" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Free" FontSize="22" FontAttributes="Bold"/>
                    <Label Text="$0 / month" FontSize="18" TextColor="Gray"/>
                    <BoxView HeightRequest="1" BackgroundColor="#E0E0E0"/>
                    <Label Text="✅  5 quizzes per day"/>
                    <Label Text="❌  No AI questions"/>
                    <Label Text="❌  No analytics"/>
                    <Label Text="❌  No leaderboard access"/>
                </VerticalStackLayout>
            </Frame>

            <!-- PREMIUM Card -->
            <Frame BackgroundColor="#6C63FF"
                   CornerRadius="16" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="⭐ Premium" FontSize="22"
                           FontAttributes="Bold" TextColor="White"/>
                    <Label Text="$4.99 / month" FontSize="18" TextColor="White"/>
                    <BoxView HeightRequest="1" BackgroundColor="White" Opacity="0.3"/>
                    <Label Text="✅  Unlimited quizzes" TextColor="White"/>
                    <Label Text="✅  AI-generated questions" TextColor="White"/>
                    <Label Text="✅  Advanced analytics" TextColor="White"/>
                    <Label Text="✅  Full leaderboard access" TextColor="White"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Upgrade Button -->
            <Button Text="🚀 Get Premium Now"
                    BackgroundColor="#6C63FF"
                    TextColor="White"
                    CornerRadius="12"
                    FontSize="18"
                    FontAttributes="Bold"
                    HeightRequest="55"
                    Command="{Binding UpgradeCommand}"/>

            <Label Text="This is a simulated payment for demo purposes."
                   FontSize="11"
                   TextColor="Gray"
                   HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
